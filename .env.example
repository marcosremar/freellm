# ==============================================================================
# FreeLLM Gateway configuration
# ==============================================================================
#
# Every value in this file has a safe default in code. The minimum viable
# setup is "set at least one provider API key below, leave everything else
# empty, run the gateway". Production deployments should review the Gateway
# Security section at minimum.
#
# Variables are grouped by purpose. Anything marked "optional" can be left
# empty or commented out and the gateway will pick a sane default.

# ------------------------------------------------------------------------------
# 1. LLM provider API keys (at least one required)
# ------------------------------------------------------------------------------
# Each variable accepts either a single key OR a comma-separated list of keys.
# When multiple keys are provided, FreeLLM rotates through them to multiply
# your free-tier capacity. Each key gets its own independent rate-limit
# budget, and a 429 on one key does not sideline the whole provider.
#
# Get free keys at:
#   Groq      https://console.groq.com
#   Gemini    https://aistudio.google.com
#   Mistral   https://console.mistral.ai
#   Cerebras  https://cloud.cerebras.ai
#   NVIDIA    https://build.nvidia.com

GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_NIM_API_KEY=

# Examples (uncomment to try):
# GROQ_API_KEY=gsk_single_key
# GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3   # stacks 3 keys = 3x the free RPM

# ------------------------------------------------------------------------------
# 2. Ollama (optional, for local models)
# ------------------------------------------------------------------------------
# Ollama runs models on your own machine so no data leaves the host. Set
# OLLAMA_MODELS to a comma-separated list of the models you have pulled
# locally (`ollama list`) so FreeLLM knows which ones to expose.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=

# Example:
# OLLAMA_MODELS=llama3,mistral,qwen2.5

# ------------------------------------------------------------------------------
# 3. Gateway security (optional, strongly recommended in production)
# ------------------------------------------------------------------------------
# FREELLM_API_KEY is the master bearer token. When set, every request must
# carry Authorization: Bearer <this value>. Leave empty for local dev only.
# FREELLM_ADMIN_KEY is a separate bearer required for mutation and inventory
# endpoints (circuit breaker reset, routing toggle, virtual keys inventory).
# If unset, the master key is enough for everything.
# ALLOWED_ORIGINS is a comma-separated CORS allowlist. Required when a
# browser-backed frontend (see section 7) hits the gateway directly.

FREELLM_API_KEY=
FREELLM_ADMIN_KEY=
ALLOWED_ORIGINS=

# Example: ALLOWED_ORIGINS=https://yoursite.com,https://staging.yoursite.com

# ------------------------------------------------------------------------------
# 4. Per-client and per-identifier rate limiting
# ------------------------------------------------------------------------------
# RATE_LIMIT_RPM / RATE_LIMIT_WINDOW_MS is the per-client-IP sliding window
# that runs before auth. It protects the gateway from dumb abuse.
#
# FREELLM_IDENTIFIER_LIMIT is the per-user sliding window that runs AFTER
# auth and tracks requests by the X-FreeLLM-Identifier header (or by
# client IP when the header is missing). Format: <max>/<windowMs>.
# FREELLM_IDENTIFIER_MAX_BUCKETS caps how many distinct identifiers the
# limiter will track at once (oldest gets LRU-evicted on overflow).

RATE_LIMIT_RPM=60
RATE_LIMIT_WINDOW_MS=60000

FREELLM_IDENTIFIER_LIMIT=60/60000
FREELLM_IDENTIFIER_MAX_BUCKETS=10000

# ------------------------------------------------------------------------------
# 5. Virtual sub-keys with soft caps (optional)
# ------------------------------------------------------------------------------
# Point FREELLM_VIRTUAL_KEYS_PATH at a JSON file declaring scoped keys that
# can carry per-key request caps, token caps, model allowlists, and expiry.
# The file is loaded at boot, Zod-validated, and counters are in-memory
# rolling 24h windows that reset on restart. Soft cap, not a billing system.
#
# Schema:
# {
#   "keys": [
#     {
#       "id": "sk-freellm-portfolio-abc123",
#       "label": "My portfolio site",
#       "dailyRequestCap": 500,
#       "dailyTokenCap": 200000,
#       "allowedModels": ["free-fast", "free"],
#       "expiresAt": "2026-07-01T00:00:00Z"
#     }
#   ]
# }

FREELLM_VIRTUAL_KEYS_PATH=

# Example: FREELLM_VIRTUAL_KEYS_PATH=./virtual-keys.json

# ------------------------------------------------------------------------------
# 6. Routing behavior
# ------------------------------------------------------------------------------
# ROUTE_TIMEOUT_MS is the hard deadline for trying providers before the
# gateway gives up and returns 429 all_providers_exhausted. Prevents hung
# requests during cascading failures.
#
# STREAM_IDLE_TIMEOUT_MS is how often the streaming chat route emits a
# keep-alive SSE comment so proxies on the path (Railway, Cloudflare,
# Vercel) do not drop slow streams. Set to 0 to disable.

ROUTE_TIMEOUT_MS=30000
STREAM_IDLE_TIMEOUT_MS=30000

# ------------------------------------------------------------------------------
# 7. Browser-safe short-lived tokens (optional)
# ------------------------------------------------------------------------------
# FREELLM_TOKEN_SECRET enables the POST /v1/tokens/issue endpoint and the
# flt.* auth branch. When set, operators can mint short-lived HMAC-signed
# tokens that are safe to ship to a browser. Tokens are bound to an origin,
# expire in at most 15 minutes, and enforce per-identifier rate limits.
#
# REQUIREMENTS:
#   - Must be at least 32 bytes of high-entropy text
#   - A short secret is a FATAL boot failure (refuses to start)
#   - Rotating this secret invalidates every outstanding token (kill switch)
#
# Generate one with any of these:
#   openssl rand -hex 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   uuidgen && uuidgen    # concat two UUIDs for 72 chars
#
# Leave empty to disable browser tokens entirely. The rest of the gateway
# runs unchanged.

FREELLM_TOKEN_SECRET=

# ------------------------------------------------------------------------------
# 8. Circuit breaker
# ------------------------------------------------------------------------------
# Per-provider circuit breaker state machine. Defaults are conservative and
# rarely need tuning.

CB_FAILURE_THRESHOLD=3
CB_SUCCESS_THRESHOLD=2
CB_TIMEOUT_MS=30000

# ------------------------------------------------------------------------------
# 9. Response cache
# ------------------------------------------------------------------------------
# In-memory LRU cache keyed on (model, messages, temperature, max_tokens,
# top_p, stop) via SHA-256. Identical non-streaming chat completions return
# the cached response with zero provider quota burn and ~0ms latency.
# Streaming requests and errors are never cached.

CACHE_ENABLED=true
CACHE_TTL_MS=3600000
CACHE_MAX_ENTRIES=1000

# ------------------------------------------------------------------------------
# 10. Logging and runtime
# ------------------------------------------------------------------------------

LOG_LEVEL=info
NODE_ENV=development
PORT=3000
