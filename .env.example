# LLM Provider API Keys
#
# Each variable accepts either a single key OR a comma-separated list of keys.
# When multiple keys are provided, FreeLLM rotates through them to multiply your
# free-tier capacity. Each key gets its own independent rate-limit budget.
#
# Examples:
#   GROQ_API_KEY=gsk_single_key
#   GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3   # 3x the free-tier RPM

GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_NIM_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Circuit Breaker
CB_FAILURE_THRESHOLD=3
CB_SUCCESS_THRESHOLD=2
CB_TIMEOUT_MS=30000

# Gateway Security (optional -- leave empty for open access)
FREELLM_API_KEY=
FREELLM_ADMIN_KEY=
ALLOWED_ORIGINS=

# Per-Client Rate Limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_WINDOW_MS=60000

# Routing Timeout (max time to try all providers before giving up)
ROUTE_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
NODE_ENV=development
